{
  "manifest_version": 3,
  "name": "StockNow Watchlist",
  "version": "1.0.0",
  "description": "Monitor DSE stocks in customizable watchlists with live data from StockNow.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open StockNow Watchlist",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://stocknow.com.bd/*",
    "https://www.dsebd.org/*",
    "https://chat.googleapis.com/*",
    "https://api.telegram.org/*",
    "https://*.tradingview.com/*"
  ]
}
